rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public read for shows, authenticated for create/update
    match /shows/{document=**} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isAdmin();
    }
    
    // Allow authenticated users to create and read their own payments
    match /payments/{document=**} {
      allow create: if request.auth != null;
      allow read: if request.auth != null 
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if request.auth != null && isAdmin();
    }
    
    // Allow authenticated users to read analytics (admin dashboards)
    match /tickets_analytics/{document=**} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && isAdmin();
    }
    
    match /profit_analytics/{document=**} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && isAdmin();
    }
    
    match /earnings_breakdown/{document=**} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && isAdmin();
    }

    // Special offers and promotions for admin panel
    match /special_offers/{document=**} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && isAdmin();
    }

    // Application settings documents (e.g. app_settings/admin, app_settings/user)
    match /app_settings/{document=**} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && isAdmin();
    }
    
    // Helper function to check if user is admin
    // In production, implement proper admin role checking
    function isAdmin() {
      return request.auth.token.admin == true 
        || request.auth.token.email_verified == true;
    }
  }
}
